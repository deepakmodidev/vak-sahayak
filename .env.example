# Enviroment variables needed to connect to the LiveKit server.
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud

# Agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch)
# Leave AGENT_NAME blank to enable automatic dispatch
# Provide an agent name to enable explicit dispatch
AGENT_NAME=

# Internally used environment variables
NEXT_PUBLIC_APP_CONFIG_ENDPOINT=
SANDBOX_ID=

# Neon (database + auth). Get these from the Neon Console (Auth -> Configuration).
DATABASE_URL=                # Neon Postgres connection string
NEON_AUTH_BASE_URL=          # Base URL of your Neon Auth instance
NEON_AUTH_COOKIE_SECRET=     # Secret for signing session cookies; must be 32+ chars

# Ringg AI (outbound "fill form by phone call"). From the Ringg dashboard.
# Calling is disabled (503 RINGG_NOT_CONFIGURED) until KEY + AGENT_ID + FROM_NUMBER_ID are all set.
RINGG_API_KEY=               # Ringg dashboard -> API key (sent as X-API-KEY)
RINGG_AGENT_ID=              # The one parameterized assistant's UUID
RINGG_FROM_NUMBER_ID=        # Purchased caller-ID number id
RINGG_WEBHOOK_SECRET=        # Shared secret to verify inbound Ringg webhooks
# Configure this webhook URL in the Ringg dashboard (subscribe to all_processing_completed):
#   https://<your-domain>/api/call/webhook?secret=<RINGG_WEBHOOK_SECRET>
