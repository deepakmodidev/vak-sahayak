# LiveKit Cloud connection (set as secrets in LiveKit Cloud on deploy)
LIVEKIT_URL=wss://<project-subdomain>.livekit.cloud
LIVEKIT_API_KEY=<your_api_key>
LIVEKIT_API_SECRET=<your_api_secret>

# Explicit agent name — must match the name the token route dispatches to.
AGENT_NAME=vak-sahayak

# Speech (Sarvam STT/TTS)
SARVAM_API_KEY=<your_sarvam_key>

# LLM brain (Groq, OpenAI-compatible endpoint)
OPENAI_API_KEY=<your_groq_or_openai_key>
# Optional: pin the first model tried in the probe chain.
GROQ_MODEL=
